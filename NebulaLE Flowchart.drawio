        <mxCell id="YydNLhTS0zoFXrXitx1l-89" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="The inner shell excitation event is a node, so the edge tag should be updated." vertex="1">
          <mxGeometry height="70" width="177.64" x="1570.6200000000003" y="990" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-90" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-85" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-91" value="">

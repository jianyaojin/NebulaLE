        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-259" parent="tR1NT1atUcalzu_eAJJ9-228" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;position2=0.48;size=31;position=0.44;fillColor=#fff2cc;strokeColor=#d6b656;rotation=-90;base=35;" value="" vertex="1">
          <mxGeometry height="283.13" width="479.52" x="-80.08" y="208.28" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-260" parent="tR1NT1atUcalzu_eAJJ9-228" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The actual path for an electron is sampled using the following equation:" vertex="1">
          <mxGeometry height="44.14" width="220.23" x="30" y="110.85999999999967" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-264" parent="tR1NT1atUcalzu_eAJJ9-228" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;Where s is the actual sampled path, lambda is the mean free path for a given electron energy obtained from an MFP table, and U is a sample drawn from a uniform distribution.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Physically, this captures the idea that the probability an electron remains unscattered decreases exponentially as its travels through a material. Full derivation can be found in the thesis of A. Theulings or T. Verduin.&lt;/div&gt;" vertex="1">
          <mxGeometry height="187.07" width="220.23" x="30" y="202.93" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-286" edge="1" parent="tR1NT1atUcalzu_eAJJ9-228" source="tR1NT1atUcalzu_eAJJ9-265" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="tR1NT1atUcalzu_eAJJ9-284">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-265" parent="tR1NT1atUcalzu_eAJJ9-228" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=14;strokeWidth=2;" value="This sampled path is compared with the stored shortest event distance. If it is shorter, then the current saved scattering event is replaced and the shortest event distance is overwritten." vertex="1">
          <mxGeometry height="100" width="284.51" x="307.75" y="430" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-267" parent="tR1NT1atUcalzu_eAJJ9-228" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;position2=0.17;size=27;position=0.15;fillColor=#fff2cc;strokeColor=#d6b656;rotation=90;base=21;" value="" vertex="1">
          <mxGeometry height="267.72" width="479.73" x="496.84" y="509.15" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-269" parent="tR1NT1atUcalzu_eAJJ9-228" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;" value="Selected Scatter Event" vertex="1">
          <mxGeometry height="70" width="150" x="674.01" y="430" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-270" parent="tR1NT1atUcalzu_eAJJ9-269" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" value="ID: 0 (None)" vertex="1">
          <mxGeometry height="20" width="150" y="30" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-271" parent="tR1NT1atUcalzu_eAJJ9-269" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" value="Distance: Infinity" vertex="1">
          <mxGeometry height="20" width="150" y="50" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-273" parent="tR1NT1atUcalzu_eAJJ9-228" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;We move to inelastic, which has ID: 1. We sample a path. Let&#39;s take for example s = 5 nm.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;5 nm &amp;lt; infinity, so:&lt;/div&gt;" vertex="1">
          <mxGeometry height="75" width="220" x="639.01" y="505" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-276" parent="tR1NT1atUcalzu_eAJJ9-228" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;" value="Selected Scatter Event" vertex="1">
          <mxGeometry height="70" width="150" x="671.51" y="590" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-277" parent="tR1NT1atUcalzu_eAJJ9-276" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" value="ID: 1 (Inelastic)" vertex="1">
          <mxGeometry height="20" width="150" y="30" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-278" parent="tR1NT1atUcalzu_eAJJ9-276" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" value="Distance: 5 nm" vertex="1">
          <mxGeometry height="20" width="150" y="50" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-279" parent="tR1NT1atUcalzu_eAJJ9-228" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;Next we evaluate elastic. This has ID: 2 and we sample for example s = 8 nm.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;8 nm &amp;gt; 5 nm, and so:&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="220" x="639.01" y="664" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-280" parent="tR1NT1atUcalzu_eAJJ9-228" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;" value="Selected Scatter Event" vertex="1">
          <mxGeometry height="70" width="150" x="674.01" y="734" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-281" parent="tR1NT1atUcalzu_eAJJ9-280" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" value="ID: 1 (Inelastic)" vertex="1">
          <mxGeometry height="20" width="150" y="30" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-282" parent="tR1NT1atUcalzu_eAJJ9-280" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" value="Distance: 5 nm" vertex="1">
          <mxGeometry height="20" width="150" y="50" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-283" parent="tR1NT1atUcalzu_eAJJ9-228" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="This would repeat until we reach the bottom of the list (In this example we have, so the next scatter event has been determined as inelastic)." vertex="1">
          <mxGeometry height="70" width="230.99" x="637.99" y="810" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-284" parent="tR1NT1atUcalzu_eAJJ9-228" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=14;strokeWidth=2;" value="After traversing the full scatter list, the function outputs the selected scattering event." vertex="1">
          <mxGeometry height="70" width="284.51" x="309.49" y="560" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-268" parent="tR1NT1atUcalzu_eAJJ9-228" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="As an example, we start with:" vertex="1">
          <mxGeometry height="20" width="220" x="637.99" y="409" as="geometry" />
        </mxCell>
        <mxCell id="fdHg4GswKJxgz0AEHUep-15" parent="tR1NT1atUcalzu_eAJJ9-228" style="verticalAlign=top;align=left;spacingTop=8;spacingLeft=2;spacingRight=12;shape=cube;size=10;direction=south;fontStyle=4;html=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;div&gt;sample_path(particle, rng)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="560" x="20" y="690" as="geometry" />
        </mxCell>
        <mxCell id="fdHg4GswKJxgz0AEHUep-16" parent="tR1NT1atUcalzu_eAJJ9-228" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;More specifically on what the code does:&lt;/div&gt;&lt;div&gt;- Create a struct object of type &quot;sample_visitor&quot; with name &quot;visitor&quot;, giving it as inputs the particle information, rng engine, and the default scattering event of ID = 0 and distance infinity.&lt;/div&gt;&lt;div&gt;- for_each (in tuple.h) is called with: for_each(*this, visitor). &quot;*this&quot; refers to the list of scattering events and &quot;visitor&quot; is the above struct object.&lt;/div&gt;&lt;div&gt;- for_each takes each scattering event in the list of scattering events and feeds it to the &quot;visitor&quot; object.&amp;nbsp;&lt;/div&gt;&lt;div&gt;- &quot;visitor&quot; is instructed to, when given a scattering event type, sample a path length using the equations shown above.&lt;/div&gt;&lt;div&gt;- If the sampled path is shorter than the distance of the current &quot;selected&quot; event, then that event is overwritten to the current scattering event, with the sampled distance.&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="533" x="27" y="720" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-48" parent="tR1NT1atUcalzu_eAJJ9-228" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="42" width="170.63" x="54.8" y="155" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-49" parent="tR1NT1atUcalzu_eAJJ9-228" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="182.3" width="225" x="30" y="395.00000000000006" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-234" edge="1" parent="tR1NT1atUcalzu_eAJJ9-189" source="tR1NT1atUcalzu_eAJJ9-232" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="tR1NT1atUcalzu_eAJJ9-228">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-232" parent="tR1NT1atUcalzu_eAJJ9-189" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=14;strokeWidth=2;" value="The next scatter event needs to be chosen via the function sample_path()" vertex="1">
          <mxGeometry height="60" width="225.99" x="347.01" y="1000" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-290" edge="1" parent="tR1NT1atUcalzu_eAJJ9-189" source="tR1NT1atUcalzu_eAJJ9-287" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="tR1NT1atUcalzu_eAJJ9-289">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tR1NT1atUcalzu_eAJJ9-287" parent="tR1NT1atUcalzu_eAJJ9-189" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=14;strokeWidth=2;" value="Attempt to move the particle by the selected scatter event distance in the direction it was travelling." vertex="1">
          <mxGeometry height="70" width="284.51" x="356.03" y="2040" as="geometry" />
        </mxCell>

        <mxCell id="YydNLhTS0zoFXrXitx1l-91" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;" value="If tracking secondary electrons is enabled, the kinetic energy of this new secondary is given as the Fermi level + omega - binding energy.&amp;nbsp;" vertex="1">
          <mxGeometry height="80" width="200" x="1788.2600000000002" y="990" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-92" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-81" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-93" value="">

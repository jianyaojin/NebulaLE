        </mxCell>
        <mxCell id="SQ9sBJwUYBfkxu-uvdz8-111" parent="fUe3NVcBme_qR7799I4q-1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;fontSize=13;" value="" vertex="1">
          <mxGeometry height="42" width="170" x="10" y="108.72340425531914" as="geometry" />
        </mxCell>
        <mxCell id="SQ9sBJwUYBfkxu-uvdz8-112" parent="fUe3NVcBme_qR7799I4q-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=15;fontStyle=5" value="Equation {1}:" vertex="1">
          <mxGeometry height="46.59574468085106" width="100" y="62.12765957446808" as="geometry" />
        </mxCell>
        <mxCell id="SQ9sBJwUYBfkxu-uvdz8-113" parent="fUe3NVcBme_qR7799I4q-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 13px;&quot;&gt;Here s is the sampled path, lambda is the mean free path for a given electron energy, and U is drawn from a uniform distribution. For the derivation refer to the thesis of A. Theulings or T. Verduin, but essentially the probability an electron remains unscattered decreases exponentially as it travels through a material.&lt;/font&gt;" vertex="1">
          <mxGeometry height="93.19148936170212" width="670" x="190" y="83.12468085106381" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-31" parent="fUe3NVcBme_qR7799I4q-1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="80" width="154.96" x="10" y="470.6170212765957" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-32" parent="fUe3NVcBme_qR7799I4q-1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="69" width="101.62" x="180" y="479.15957446808505" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-33" parent="fUe3NVcBme_qR7799I4q-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=15;fontStyle=5" value="Equation {2}:" vertex="1">
          <mxGeometry height="46.59574468085106" width="100" y="424.02127659574467" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-34" parent="fUe3NVcBme_qR7799I4q-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=13;" value="The auxiliary variable z is used for calculation of T and R, the reflection and transmission coefficients. Note that here Delta U is not a random sample drawn from a uniform distribution, but rather the inner potential of the material. When sampling, one can simply draw from a uniform distribution and if it is smaller than for example the transmission coefficient, then transmission occurs. T and R are related simply via subtraction from 1." vertex="1">
          <mxGeometry height="129.6914893617021" width="570" x="290" y="470.6170212765957" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-59" parent="fUe3NVcBme_qR7799I4q-1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="40" width="252.26" x="10" y="641.4680851063829" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-60" parent="fUe3NVcBme_qR7799I4q-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=15;fontStyle=5" value="Equation {3}:" vertex="1">
          <mxGeometry height="46.59574468085106" width="100" y="594.8723404255319" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-61" parent="fUe3NVcBme_qR7799I4q-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=13;" value="Here v_new is the particle&#39;s new direction, v_prev is the direction it was previously travelling in, theta is the polar angle with respect to the previous travelling direction (It is sampled directly as cos(theta)), and n is the uniformly sampled normal direction to the particle&#39;s previous direction." vertex="1">
          <mxGeometry height="114.93617021276594" width="590" x="270" y="615.063829787234" as="geometry" />
        </mxCell>

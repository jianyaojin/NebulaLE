          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-36" parent="SQ9sBJwUYBfkxu-uvdz8-118" style="whiteSpace=wrap;html=1;fontSize=13;" value="If the electron is transmitted, refraction occurs and the direction of the electron is updated according to Snell&#39;s law (equation 2.17 in Luc&#39;s thesis). The kinetic energy of the electron is updated, the current material it is in is updated, and the function &lt;b&gt;EXITS&lt;/b&gt;" vertex="1">
          <mxGeometry height="160" width="191.14" x="804.048" y="860" as="geometry" />
        </mxCell>

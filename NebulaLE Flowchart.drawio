          </mxGeometry>
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-8" edge="1" parent="tR1NT1atUcalzu_eAJJ9-289" source="VxDDV8BiFYrTW_ye1SgX-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="VxDDV8BiFYrTW_ye1SgX-5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-4" parent="tR1NT1atUcalzu_eAJJ9-289" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=14;strokeWidth=2;" value="Reset the temporary location reference point &quot;AABB&quot; to (0,0,0)." vertex="1">
          <mxGeometry height="70" width="211.12" x="385.47" y="230" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-5" parent="tR1NT1atUcalzu_eAJJ9-289" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=14;strokeWidth=2;" value="&lt;div&gt;Read our &quot;location&quot; marker and traverse the tree to the subdivided octant that it points to.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&quot;AABB&quot; shifts to the center of a new octant along each step. It&#39;s new location allows the next segment of the &quot;location&quot; marker to be decoded.&lt;/div&gt;" vertex="1">
          <mxGeometry height="135" width="244.53" x="368.76000000000005" y="345" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-6" parent="tR1NT1atUcalzu_eAJJ9-289" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;position2=1;size=30;position=0.62;fillColor=#fff2cc;strokeColor=#d6b656;rotation=90;base=21;" value="" vertex="1">
          <mxGeometry height="270" width="95.46" x="691.5" y="60.00000000000091" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-7" parent="tR1NT1atUcalzu_eAJJ9-289" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The &quot;location&quot; marker always points to a node on the tree with respect to (0,0,0), so this reference point needs to be reset every cycle of the loop for the &quot;location&quot; marker to be read out correctly." vertex="1">
          <mxGeometry height="83.74" width="215" x="651.72" y="153.53000000000156" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-12" edge="1" parent="tR1NT1atUcalzu_eAJJ9-289" source="VxDDV8BiFYrTW_ye1SgX-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="VxDDV8BiFYrTW_ye1SgX-13" value="&amp;nbsp;no&amp;nbsp;">
          <mxGeometry relative="1" as="geometry">

          <mxGeometry height="270" width="183.04" x="153.96" y="560" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-19" parent="tR1NT1atUcalzu_eAJJ9-289" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;Any given non-leaf node on the octant tree contains indexes for the 8 octants that subdivide it.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Leaf nodes on the octant tree contain indexes for the triangles it contains.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;We want to find if there are triangles the particle will intersect with, so we need triangle information, and therefore we must search the octree until a leaf node is found.&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="215" x="122" y="610" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-22" parent="tR1NT1atUcalzu_eAJJ9-289" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="150" width="261.7" x="45.2" y="100" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-24" parent="tR1NT1atUcalzu_eAJJ9-289" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="An &quot;octree&quot; is a way to subdivide a 3D space by repeatedly partitioning it into smaller spaces. For a cuboidal space, each &quot;cell&quot; is subdivided into 8 smaller cuboids:" vertex="1">
          <mxGeometry height="53.74" width="318.28" x="21.72" y="46.26" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-25" parent="tR1NT1atUcalzu_eAJJ9-289" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;The &quot;location&quot; marker here is a long binary number. &quot;location&quot; = 1 means a series of 0&#39;s followed by a single 1. Somewhere halfway through this traversal algorithm, location may look something like this:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&quot;location&quot; = 011101010&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="318.28" x="21.72" y="260" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-26" parent="tR1NT1atUcalzu_eAJJ9-289" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;Each group of 3 digits is a description of where to move relative to the current cell center or &quot;AABB&quot; location. The above example thus encodes three cells, whose relative locations are: 011, 101 and 010. 0 means lower and 1 means higher, so the above example &quot;location&quot; code is saying:&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="318.28" x="18.72000000000008" y="362" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-27" parent="tR1NT1atUcalzu_eAJJ9-289" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;- 011: lower x, higher y, higher z.&lt;/div&gt;&lt;div&gt;- 101: higher x, lower y, higher z.&lt;/div&gt;&lt;div&gt;- 010: lower x, higher y, lower z.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;By following these instructions in order and updating the &quot;AABB&quot; or cell center after each move, Nebula traverses to the most recent cell (or node in the tree) that the location encodes.&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="318.28" x="21.72" y="460" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-30" parent="tR1NT1atUcalzu_eAJJ9-289" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;position2=0.38;size=33;position=0.26;fillColor=#fff2cc;strokeColor=#d6b656;rotation=90;base=21;" value="" vertex="1">
          <mxGeometry height="270" width="240.82" x="653.51" y="275.67" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-31" parent="tR1NT1atUcalzu_eAJJ9-289" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&quot;AABB&quot; or the center of the current octant, updates with each step. As an example:" vertex="1">
          <mxGeometry height="56.47" width="215" x="686.41" y="293.53" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-34" parent="tR1NT1atUcalzu_eAJJ9-289" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="175" width="184.96" x="701.43" y="350" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-35" parent="tR1NT1atUcalzu_eAJJ9-289" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Where the red dot is &quot;AABB&quot; in 3D space." vertex="1">
          <mxGeometry height="70" width="103.59" x="686.41" y="450" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-91" edge="1" parent="tR1NT1atUcalzu_eAJJ9-289" source="VxDDV8BiFYrTW_ye1SgX-88" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="VxDDV8BiFYrTW_ye1SgX-90">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-88" parent="tR1NT1atUcalzu_eAJJ9-289" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=14;strokeWidth=2;" value="Flip the sign of the index to get the actual index to the node" vertex="1">
          <mxGeometry height="70" width="211.12" x="385.46000000000004" y="693" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-93" edge="1" parent="tR1NT1atUcalzu_eAJJ9-289" source="VxDDV8BiFYrTW_ye1SgX-90" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="VxDDV8BiFYrTW_ye1SgX-92">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-90" parent="tR1NT1atUcalzu_eAJJ9-289" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=14;strokeWidth=2;" value="&lt;div&gt;Set up variables to store information:&lt;/div&gt;&lt;div&gt;- intersect: Saves distance to the next significant event&lt;/div&gt;&lt;div&gt;- target: specifies what the event is. if target &amp;gt;= 0, the particle hits a triangle. If target = -1, the particle leaves the octree on an x face. target = -2 is leaving on a y face and target = -4 is leaving on a z face.&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="294.54" x="343.75" y="810" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-92" parent="tR1NT1atUcalzu_eAJJ9-289" style="rounded=1;whiteSpace=wrap;html=1;absoluteArcSize=1;arcSize=14;strokeWidth=2;" value="Calculate the distance it would take for the particle to reach an x,y or z boundary of the octant. (t.x, t.y and t.z)." vertex="1">
          <mxGeometry height="100" width="191.25" x="395.39" y="980" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-98" edge="1" parent="tR1NT1atUcalzu_eAJJ9-289" source="VxDDV8BiFYrTW_ye1SgX-94" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="VxDDV8BiFYrTW_ye1SgX-96" value="t.y is the smallest">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-99" edge="1" parent="tR1NT1atUcalzu_eAJJ9-289" source="VxDDV8BiFYrTW_ye1SgX-94" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="VxDDV8BiFYrTW_ye1SgX-95" value="&amp;nbsp;t.x is the smallest&amp;nbsp;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="VxDDV8BiFYrTW_ye1SgX-100" edge="1" parent="tR1NT1atUcalzu_eAJJ9-289" source="VxDDV8BiFYrTW_ye1SgX-94" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="VxDDV8BiFYrTW_ye1SgX-97" value="&amp;nbsp;t.z is the smallest&amp;nbsp;">

          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-56" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;" value="&lt;div&gt;If the particle scatters inelastically:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;We retrieve the particle from memory and sample the energy lost by the primary during the collision (denoted by omega)&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="410" x="1241.9250000000002" y="430" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-57" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-54" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-58" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-869.2717500000002" y="4065" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-58" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;" value="An azimuthal angle phi is chosen randomly using a uniform distribution. The particle&#39;s new direction is calculated according to equation {3}." vertex="1">
          <mxGeometry height="70" width="410" x="255.05000000000007" y="570" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-62" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-58" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-63" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-1094.2717500000006" y="4205" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-63" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;" value="If the particle&#39;s energy is below 200 eV, and if phonon scattering is enabled, a small amount of energy is subtracted from the particle&#39;s kinetic energy (around a couple of tens of meV)" vertex="1">
          <mxGeometry height="70" width="410" x="20" y="690" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-66" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-58" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-67" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-1094.2717500000006" y="4205" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-67" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;" value="If the particle&#39;s energy is above 200 eV, it scattered elastically and so does not lose any energy." vertex="1">
          <mxGeometry height="70" width="410" x="490.1" y="690" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-68" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-67" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;dashed=1;" target="YydNLhTS0zoFXrXitx1l-69" value="">
          <mxGeometry relative="1" as="geometry">

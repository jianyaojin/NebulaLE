        <mxCell id="YydNLhTS0zoFXrXitx1l-42" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;" value="Particle&#39;s next event is retrieved from memory" vertex="1">
          <mxGeometry height="50" width="140" x="776.4875000000001" y="40" as="geometry" />

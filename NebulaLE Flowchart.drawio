        <mxCell id="YydNLhTS0zoFXrXitx1l-95" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;" value="If the energy loss doesn&#39;t exceed the band gap, we assume loss due to longitudinal optical phonons. Omega is subtracted from the primary energy but no secondary is generated, and the primary is also not deflected." vertex="1">
          <mxGeometry height="110" width="248.62" x="1310.0000000000002" y="840" as="geometry" />
        </mxCell>

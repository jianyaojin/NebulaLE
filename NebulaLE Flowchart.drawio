          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-69" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;dashed=1;" value="Atomic recoil loss is also possible via the Kieft and Bosch method, but is switched off by default." vertex="1">
          <mxGeometry height="70" width="280" x="370" y="810" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-70" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-67" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-71" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-616.2717500000002" y="4325" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-71" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="A scatter event is a node, so the edge tag should be updated." vertex="1">
          <mxGeometry height="70" width="142" x="690" y="810" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-72" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-67" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-73" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-74.67175000000088" y="4325" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-73" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="A scatter event has occurred, so the scattering counter should be updated." vertex="1">
          <mxGeometry height="70" width="148.2" x="872" y="810" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-74" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-56" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-75" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="342.5882499999992" y="4065" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-75" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="The edep function logs energy changing scattering events, and the energy that is lost by the primary is omega, so the &quot;energy deposition&quot; that is logged, is exactly this omega." vertex="1">
          <mxGeometry height="100" width="167.74" x="1126.9750000000001" y="550" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-76" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-63" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-77" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1224.2762499999988" y="4325" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-77" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="The energy of the electron is changed by this event, so the edep function will log this event." vertex="1">
          <mxGeometry height="70" width="210" x="120" y="810" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-78" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-56" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-79" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1525.2612499999993" y="4065" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-79" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;" value="&lt;div&gt;The binding energy of the secondary electron in the collision is sampled. This choose whether we perform a valence excitation or an inner shell excitation.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Implementation detail: Intuitively we would expect to sample a binding energy (i.e. choose a shell that the secondary electron comes from), and then reject if that binding energy is larger than the energy loss omega. The assumption is made, however, that we instead first sample an energy loss omega, and that the shell with the highest binding energy below the sampled omega value dominates the result. This is then how we choose the shell from which the electron comes from, and it comes with a significant speed advantage.&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="432.16" x="1334.7150000000001" y="550" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-80" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-79" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-81" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2586.4212499999994" y="4185" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-81" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;" value="If valence excitation, we check omega next.&amp;nbsp;&amp;nbsp;" vertex="1">
          <mxGeometry height="40" width="152.16" x="1233.3300000000002" y="750" as="geometry" />
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-82" edge="1" parent="YydNLhTS0zoFXrXitx1l-41" source="YydNLhTS0zoFXrXitx1l-79" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;rounded=1;curved=0;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;startSize=6;endSize=6;" target="YydNLhTS0zoFXrXitx1l-83" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2582.73125" y="4185" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="YydNLhTS0zoFXrXitx1l-83" parent="YydNLhTS0zoFXrXitx1l-41" style="whiteSpace=wrap;html=1;" value="If inner shell excitation, the method of Ivanchenko / Kieft &amp;amp; Bosch is followed to choose the inelastic scattering angle." vertex="1">
          <mxGeometry height="70" width="177.64" x="1690.6200000000003" y="750" as="geometry" />
        </mxCell>
